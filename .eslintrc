{
    "extends": ["next-app","prettier"],
    "plugins": ["react","prettier"],
    "rules": {
        "prettier/prettier":[
            "warn",{
                "arrowParens": "always",
                "semi": false,
                "trailingComma": "all",
                "tabWidth": 2,
                "endOfLine": "auto",
                "useTabs": false,
                "singleQuote": true,
                "printWidth": 120,
                "jsxSingleQuote": true
            }
        ]
    }
}